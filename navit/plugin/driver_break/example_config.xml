<?xml version="1.0" encoding="UTF-8"?>
<navit>
    <!-- Rest Plugin Configuration Examples -->
    
    <!-- Example 1: Car with default settings -->
    <osd type="rest" enabled="yes">
        <attr name="type" value="car"/>
    </osd>
    
    <!-- Example 2: Truck with custom database path -->
    <osd type="rest" enabled="yes" data="/home/user/.navit/rest_truck.db">
        <attr name="type" value="truck"/>
    </osd>
    
    <!-- Example 3: Car with custom database location -->
    <osd type="rest" enabled="yes" data="/var/lib/navit/rest_plugin.db">
        <attr name="type" value="car"/>
    </osd>
    
    <!-- Menu integration example -->
    <!-- Add to your menu XML:
    <a name='Settings Rest'><text>Rest &amp; Break Settings</text>
        <img src='gui_settings' onclick='rest_configure()'><text>Configure</text></img>
        <img src='gui_settings' onclick='rest_suggest_stop()'><text>Suggest Rest Stop</text></img>
        <img src='gui_settings' onclick='rest_show_history()'><text>Rest Stop History</text></img>
        <img src='gui_settings' onclick='rest_start_break()'><text>Start Break</text></img>
        <img src='gui_settings' onclick='rest_end_break()'><text>End Break</text></img>
    </a>
    -->
</navit>
