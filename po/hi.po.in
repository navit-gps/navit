#~ msgid "No config file navit.xml, navit.xml.local found\n"
#~ msgstr "navit.xml, navit.xml.local कॉन्फ़िग फ़ाइल नहीं मिली\n"

#, c-format
#~ msgid "Error parsing config file '%s': %s\n"
#~ msgstr "कॉन्फ़िग फ़ाइल '%s' पार्स करते समय त्रुटि: %s\n"

#, c-format
#~ msgid "Using config file '%s'\n"
#~ msgstr "कॉन्फ़िग फ़ाइल '%s' का उपयोग किया जा रहा है\n"

#, c-format
#~ msgid "Error: No configuration found in config file '%s'\n"
#~ msgstr "त्रुटि: कॉन्फ़िग फ़ाइल '%s' में कोई कॉन्फ़िगरेशन नहीं मिला\n"

#~ msgid ""
#~ "Internal initialization failed, exiting. Check previous error messages.\n"
#~ msgstr ""
#~ "आंतरिक प्रारंभिककरण विफल, बाहर निकला जा रहा है। कृपया पहले के त्रुटि संदेश देखें।\n"

#~ msgid "Select a search radius from screen center"
#~ msgstr "स्क्रीन के केंद्र से खोज-त्रिज्या चुनें"

#, c-format
#~ msgid "Set destination to %ld, %ld \n"
#~ msgstr "तव्य को %ld, %ld पर निर्धारित करें\n"

#, c-format
#~ msgid "Set map to %ld, %ld \n"
#~ msgstr "मानचित्र को %ld, %ld पर स्थापित करें\n"

#, c-format
#~ msgid "Set next visit to %ld, %ld \n"
#~ msgstr "अगली यात्रा को %ld, %ld पर निर्धारित करें\n"

#~ msgid "Select a distance to look for (km)"
#~ msgstr "खोज की दूरी चुनें (किमी में)"

#~ msgid "Distance(m)"
#~ msgstr "दूरी (मीटर)"

#, c-format
#~ msgid "Route %4.0fkm    %02d:%02d ETA"
#~ msgstr "मार्ग %4.0f कि.मी. %02d:%02d अनुमानित आगमन समय"

#~ msgid "partial match"
#~ msgstr "आंशिक मिलान"

#~ msgid "Map data (c) OpenStreetMap contributors, ODBL"
#~ msgstr "मानचित्र डेटा (c) OpenStreetMap योगदानकर्ताओं द्वारा, ODBL"

#~ msgid ""
#~ "Current map location %s is not available\n"
#~ "Please restart Navit after you attach an SD card or select a different "
#~ "map location."
#~ msgstr ""
#~ "वर्तमान मानचित्र स्थान %s उपलब्ध नहीं है\n"
#~ "कृपया SD कार्ड जोड़ने या अन्य मानचित्र स्थान चुनने के बाद Navit को पुनरारंभ करें।"

#~ msgid "Downloaded maps"
#~ msgstr "डाउनलोड किए गए मानचित्र"

#~ msgid "filenamePath"
#~ msgstr "फ़ाइल नाम पथ"

#~ msgid ""
#~ "New location set to %s\n"
#~ "Restart Navit to apply the changes."
#~ msgstr ""
#~ "नया स्थान %s पर सेट किया गया\n"
#~ "परिवर्तनों को लागू करने के लिए Navit पुनरारंभ करें।"

#~ msgid "Searching..."
#~ msgstr "खोज जारी है..."

#~ msgid "Backing up..."
#~ msgstr "बैकअप लिया जा रहा है"

#~ msgid "Restoring..."
#~ msgstr "पुनर्स्थापित किया जा रहा है"

#, c-format
#~ msgid "%d m"
#~ msgstr "%d मी"

#, c-format
#~ msgid "in %d m"
#~ msgstr "%d मी में"

#, c-format
#~ msgid "then leave the roundabout at the %1$s %2$s"
#~ msgstr "फिर गोल चक्कर से %1$s %2$s पर बाहर निकलें"
