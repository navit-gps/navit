msgid "Running from source directory\n"
msgstr "स्रोत निर्देशिका से चल रहा है\n"

#. libc of navit returns "dummy"
msgid "Error getting current path. use ./ \n"
msgstr ""

#, c-format
msgid "setting '%s' to '%s'\n"
msgstr "%s' को '%s' पर सेट किया जा रहा है\n"

#. TRANSLATORS: the following counts refer to streets
msgid "zeroth"
msgstr "शून्यवाँ"

msgid "first"
msgstr "पहला"

msgid "second"
msgstr "दूसरा"

msgid "third"
msgstr "तीसरा"

msgid "fourth"
msgstr "चौथा"

msgid "fifth"
msgstr "पाँचवाँ"

msgid "sixth"
msgstr "छठा"

#. TRANSLATORS: the following counts refer to roundabout exits
msgid "zeroth exit"
msgstr "सातवाँ"

msgid "first exit"
msgstr "पहला निकास"

msgid "second exit"
msgstr "दूसरा निकास"

msgid "third exit"
msgstr "तीसरा निकास"

msgid "fourth exit"
msgstr "चौथा निकास"

msgid "fifth exit"
msgstr "पाँचवाँ निकास"

msgid "sixth exit"
msgstr "छठा निकास"

#, c-format
msgid "%d feet"
msgstr "%d फ़ीट"

#, c-format
msgid "in %d feet"
msgstr "%d फ़ीट"

#, c-format
msgid "%d.%d miles"
msgstr "%d.%d मील"

#, c-format
msgid "in %d.%d miles"
msgstr "%d.%d मील"

#, c-format
msgid "one mile"
msgid_plural "%d miles"
msgstr[0] "एक मील"
msgstr[1] "%d मील"

#, c-format
msgid "in one mile"
msgid_plural "in %d miles"
msgstr[0] "एक मील में"
msgstr[1] "%d मील में"

#, c-format
msgid "%d meters"
msgstr "%d मीटर"

#, c-format
msgid "in %d meters"
msgstr "%d मीटर में"

#, c-format
msgid "%d.%d kilometers"
msgstr "%d.%d किलोमीटर"

#, c-format
msgid "in %d.%d kilometers"
msgstr "%d.%d किलोमीटर में"

#, c-format
msgid "one kilometer"
msgid_plural "%d kilometers"
msgstr[0] "एक किलोमीटर"
msgstr[1] "%d किलोमीटर"

#, c-format
msgid "in one kilometer"
msgid_plural "in %d kilometers"
msgstr[0] "ek kilometer mein"
msgstr[1] "%d kilometero mein"

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Systematic Street Name 3: Separator (Space if required), 4: Street Name
#, c-format
msgid "%1$sonto the %2$s%3$s%4$s"
msgstr "%1$s %2$s%3$s%4$s पर जाएँ"

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Street Name
#, c-format
msgid "%1$sonto %2$s"
msgstr "%1$s %2$s पर जाएँ"

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Street Name. Masculine form. The stuff after | doesn't have to be included
#, c-format
msgid "%1$sonto %2$s|masculine form"
msgstr "%1$s  से %2$s पर जाएँ"

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Street Name. Feminine form. The stuff after | doesn't have to be included
#, c-format
msgid "%1$sonto %2$s|feminine form"
msgstr "%1$s से %2$s पर जाएँ"

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Street Name. Neuter form. The stuff after | doesn't have to be included
#, c-format
msgid "%1$sonto %2$s|neuter form"
msgstr "%1$s से %2$s पर जाएँ"

msgid "onto the motorway ramp"
msgstr "dhalan mein"

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Street Name 3: Separator (Space if required), 4: Systematic Street Name
#, c-format
msgid "%sinto %s%s%s"
msgstr "%ssheher mein %s%s%s"

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Street Name 3: Separator (Space if required), 4: Systematic Street Name. Masculine form. The stuff after | doesn't have to be included
#, c-format
msgid "%sinto %s%s%s|masculine form"
msgstr "%ssheher mein %s%s%s"

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Street Name 3: Separator (Space if required), 4: Systematic Street Name. Feminine form. The stuff after | doesn't have to be included
#, c-format
msgid "%sinto %s%s%s|feminine form"
msgstr "%ssheher mein %s%s%s"

#. TRANSLATORS: Arguments: 1: Prefix (Space if required) 2: Street Name 3: Separator (Space if required), 4: Systematic Street Name. Neuter form. The stuff after | doesn't have to be included
#, c-format
msgid "%sinto %s%s%s|neuter form"
msgstr "%ssheher mein %s%s%s"

#. TRANSLATORS: gives the name of the next road to turn into (into the E17)
#, c-format
msgid "%sinto the %s"
msgstr "%s से %s पर जाएँ"

msgid "When possible, please turn around"
msgstr "जब संभव हो, कृपया चारों ओर मोड़"

#. TRANSLATORS: the argument is the destination to follow
#, c-format
msgid "towards %s"
msgstr "%s की ओर"

#, c-format
msgid "Follow the road for the next %s"
msgstr "अगले%s के लिए सड़क का पालन करें"

msgid "Enter the roundabout soon"
msgstr "जल्द ही गोल चक्कर में प्रवेश करें"

#. TRANSLATORS: %s is the distance to the roundabout
#, c-format
msgid "Enter the roundabout %s"
msgstr "गोल चक्कर में प्रवेश करें %s"

msgid "then enter the roundabout"
msgstr ""

#. TRANSLATORS: first arg. is the manieth exit, second arg. is the destination to follow
#, c-format
msgid "Leave the roundabout at the %1$s %2$s"
msgstr "%1$s %2$s के राउंडअबाउट छोड़ें"

msgid "soon"
msgstr "जल्दी"

msgid "now"
msgstr "अब"

msgid "then"
msgstr "तो"

#. TRANSLATORS: the arg. is the phrase 'onto ...'. Right merge, the stuff after | doesn't have to be included.
#, c-format
msgid "then merge%1$s|right"
msgstr "फिर दाएँ%1$s से मिलें"

#. TRANSLATORS: the first arg. is distance, the second is the phrase 'onto ...'. Right merge, the stuff after | doesn't have to be included.
#, c-format
msgid "Merge %1$s%2$s|right"
msgstr "दाएँ %1$s%2$s से मिलें"

#. TRANSLATORS: the arg. is the phrase 'onto ...'. Left merge, the stuff after | doesn't have to be included.
#, c-format
msgid "then merge%1$s|left"
msgstr "फिर बाएँ%1$s से मिलें"

#. TRANSLATORS: the first arg. is distance, the second is the phrase 'onto ...'. Left merge, the stuff after | doesn't have to be included.
#, c-format
msgid "Merge %1$s%2$s|left"
msgstr "बाएँ %1$s%2$s से मिलें"

msgid "on your left"
msgstr "आपके बाईं ओर"

msgid "on your right"
msgstr "आपके दाईं ओर"

#. TRANSLATORS: the first arg. is exit ref and/or name, the second is the direction of exit and the third is distance
#, c-format
msgid "Take exit %1$s %2$s %3$s"
msgstr "निकास %1$s %2$s %3$s लें"

#. TRANSLATORS: the first arg. is the direction of exit, the second is distance, the third is destination
#, c-format
msgid "Take the exit %1$s %2$s%3$s"
msgstr "निकास %1$s %2$s%3$s लें"

#. TRANSLATORS: as in "Keep right at interchange 42 Greenmond-West"
msgid "at interchange"
msgstr "इंटरचेंज पर"

msgid "at exit"
msgstr "निकास पर"

#. TRANSLATORS: the arg. is where to do the maneuver
#, c-format
msgid "then continue straight%1$s"
msgstr "फिर सीधे आगे बढ़ें%1$s"

#. TRANSLATORS: the first arg. is distance, the second is where to do the maneuver, the third is destination
#, c-format
msgid "Continue straight %1$s%2$s%3$s"
msgstr "सीधे आगे बढ़ें %1$s%2$s%3$s"

#. TRANSLATORS: the arg. is where to do the maneuver
#, c-format
msgid "then keep right%1$s"
msgstr "फिर दाएँ रहें%1$s"

#. TRANSLATORS: the first arg. is distance, the second is where to do the maneuver, the third is destination
#, c-format
msgid "Keep right %1$s%2$s%3$s"
msgstr "दाएँ रहें %1$s%2$s%3$s"

#. TRANSLATORS: the arg. is where to do the maneuver
#, c-format
msgid "then keep left%1$s"
msgstr "फिर बाएँ रहें%1$s"

#. TRANSLATORS: the first arg. is distance, the second is where to do the maneuver, the third is destination
#, c-format
msgid "Keep left %1$s%2$s%3$s"
msgstr "बाएँ रहें %1$s%2$s%3$s"

#. TRANSLATORS: "right" as in "turn right"
msgid "right"
msgstr "दायाँ"

#. TRANSLATORS: "left" as in "turn left"
msgid "left"
msgstr "बांया"

#. TRANSLATORS: as in "turn easily right"
msgid "easily "
msgstr "आसानी से "

#. TRANSLATORS: as in "turn strongly right"
msgid "strongly "
msgstr "दृढ़ता से "

#, c-format
msgid "then take the %1$s road to the %2$s"
msgstr ""

#, c-format
msgid "Take the %1$s road to the %2$s"
msgstr "%1$s %2$s के लिए सड़क ले लो"

#, c-format
msgid "after %i roads"
msgstr "%i के बाद सड़कों"

#. TRANSLATORS: the first arg. is strength, the second is direction, the third is distance, the fourth is destination
#, c-format
msgid "Turn %1$s%2$s %3$s%4$s"
msgstr "%1$s%2$s %3$s%4$s मुड़ें"

#. TRANSLATORS: Left U-turn, the stuff after | doesn't have to be included.
msgid "then make a U-turn|left"
msgstr "फिर यू-टर्न लें"

#. TRANSLATORS: the arg. is distance. Left U-turn, the stuff after | doesn't have to be included.
#, c-format
msgid "Make a U-turn %1$s|left"
msgstr "यू-टर्न लें %1$s"

#. TRANSLATORS: Right U-turn, the stuff after | doesn't have to be included.
msgid "then make a U-turn|right"
msgstr "फिर यू-टर्न लें"

#. TRANSLATORS: the arg. is distance. Right U-turn, the stuff after | doesn't have to be included.
#, c-format
msgid "Make a U-turn %1$s|right"
msgstr "यू-टर्न लें %1$s"

#. An empty placeholder that we can use in the future for
#. * some motorway commands that are now suppressed but we
#. * can in some cases make it say here :
#. * 'follow destination blabla' without any further driving instructions,
#. * in cases where relevant destination info is available.
#. * Even if there is no driving command to be announced, in some cases
#. * there is an overhead roadsign in preparation of an upcoming road-split,
#. * and then we can give useful info to the driver.
#. *
#. *  UNTESTED !
#. *
#.
msgid "follow"
msgstr ""

msgid "then you have reached your destination."
msgstr "तब आप अपने गंतव्य पर पहुँच चुके हैं।"

#. TRANSLATORS: the arg. is distance
#, c-format
msgid "You have reached your destination %s"
msgstr "आप अपने गंतव्य पर पहुँच चुके हैं%s"

msgid "Interchange"
msgstr "इंटरचेंज"

msgid "Exit"
msgstr "निकास"

